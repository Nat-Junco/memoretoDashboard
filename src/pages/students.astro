---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Alumnos" active="students">
  <div class="page-header">
    <div>
      <h1 id="titulo-grupo">Alumnos</h1>
      <p class="subtitle" id="subtitulo">Cargando...</p>
    </div>
    <a href="/assign" class="btn btn-primary">+ Nuevo grupo</a>
  </div>

  <!-- Selector de grupo -->
  <div class="card filter-bar">
    <label for="grupo-select">Filtrar por grupo:</label>
    <select id="grupo-select">
      <option value="">Cargando grupos...</option>
    </select>
  </div>

  <!-- Lista de alumnos -->
  <div id="students-list">
    <p class="muted" style="text-align:center; padding:2rem;">Cargando alumnos...</p>
  </div>
</BaseLayout>

<script>
  const API   = 'http://localhost:5000';
  const token = localStorage.getItem('token');
  if (!token) window.location.href = '/';

  function formatTiempo(segundos: number) {
    if (!segundos) return '0m 0s';
    const m = Math.floor(segundos / 60);
    const s = segundos % 60;
    return `${m}m ${s}s`;
  }

  function renderEstudiantes(grupo: any, estudiantes: any[], intentosPor: Record<number, any[]>) {
    document.getElementById('titulo-grupo')!.textContent  = `Alumnos — ${grupo.nombre}`;
    document.getElementById('subtitulo')!.textContent     = `${estudiantes.length} estudiante${estudiantes.length !== 1 ? 's' : ''} registrado${estudiantes.length !== 1 ? 's' : ''}`;

    const wrap = document.getElementById('students-list')!;

    if (!estudiantes.length) {
      wrap.innerHTML = '<p class="muted" style="text-align:center;padding:2rem;">No hay alumnos en este grupo aún.</p>';
      return;
    }

    wrap.innerHTML = estudiantes.map(e => {
      const intentosValidos = (intentosPor[e.estudiante_id] ?? []).filter((i: any) => i.dificultad != null);
      const filasIntentos = intentosValidos.length
        ? intentosValidos.map((i: any) => `
            <tr>
              <td class="muted">${i.ultima_vez ?? '—'}</td>
              <td>#${i.memoreto_id ?? '—'}</td>
              <td>${i.dificultad ?? '—'}</td>
              <td class="points">${i.total_intentos ?? 0}</td>
              <td>${i.veces_completado ?? 0}</td>
              <td>${formatTiempo(i.mejor_tiempo ?? 0)}</td>
              <td>
                <span class="badge ${i.veces_completado > 0 ? 'badge-success' : 'badge-danger'}">
                  ${i.veces_completado > 0 ? '✓ Completado' : '✗ Fallido'}
                </span>
              </td>
            </tr>
          `).join('')
        : `<tr><td colspan="6" class="muted" style="text-align:center">Sin intentos registrados aún</td></tr>`;
      return `
        <div class="card student-card">
          <div class="student-header">
            <div class="student-avatar">${e.nombre?.[0] ?? '?'}${e.apellido?.[0] ?? ''}</div>
            <div class="student-info">
              <h2>${e.nombre} ${e.apellido}</h2>
              <p class="muted">${e.correo ?? ''}</p>
            </div>
            <div class="student-stats">
              <div class="stat">
                <span class="stat-label">Puntos</span>
                <span class="stat-value points">${e.puntos_totales ?? 0}</span>
              </div>
              <div class="stat">
                <span class="stat-label">Nivel</span>
                <span class="stat-value">${e.nivel_actual ?? 0}</span>
              </div>
              <div class="stat">
                <span class="stat-label">Tiempo total</span>
                <span class="stat-value">${formatTiempo(e.tiempo_total)}</span>
              </div>
            </div>
          </div>

          <div class="intentos">
            <h3>Historial de intentos</h3>
            <table class="table">
              <thead>
                <tr>
                  <th>Última vez</th>
                  <th>Memoreto ID</th>
                  <th>Dificultad</th>
                  <th>Intentos</th>
                  <th>Completados</th>
                  <th>Mejor tiempo</th>
                  <th>Estado</th>
                </tr>
              </thead>
              <tbody>${filasIntentos}</tbody>
            </table>
          </div>
        </div>
      `;
    }).join('');
  }

  async function cargarGrupo(grupo_id: number) {
    document.getElementById('students-list')!.innerHTML =
      '<p class="muted" style="text-align:center;padding:2rem;">Cargando alumnos...</p>';

    // Detalle del grupo y sus estudiantes en paralelo
    const [resGrupo, resEstudiantes] = await Promise.all([
      fetch(`${API}/grupos/${grupo_id}`, { headers: { Authorization: `Bearer ${token}` } }),
      fetch(`${API}/grupos/${grupo_id}/estudiantes`, { headers: { Authorization: `Bearer ${token}` } }),
    ]);

    const grupo       = await resGrupo.json();
    const estudiantes = await resEstudiantes.json();

    // Cargar intentos de cada estudiante en paralelo
    const intentosResultados = await Promise.all(
      estudiantes.map((e: any) =>
        fetch(`${API}/intentos/estudiante/${e.estudiante_id}`, {
          headers: { Authorization: `Bearer ${token}` }
        }).then(r => r.json()).catch(() => [])
      )
    );

    // Mapear intentos por estudiante_id
    const intentosPor: Record<number, any[]> = {};
    estudiantes.forEach((e: any, i: number) => {
      intentosPor[e.estudiante_id] = intentosResultados[i];
    });

    renderEstudiantes(grupo, estudiantes, intentosPor);
  }

  // Cargar grupos en el select
  const resGrupos = await fetch(`${API}/grupos`, {
    headers: { Authorization: `Bearer ${token}` }
  });
  const grupos = await resGrupos.json();
  const select  = document.getElementById('grupo-select') as HTMLSelectElement;

  if (!grupos.length) {
    select.innerHTML = '<option value="">Sin grupos</option>';
    document.getElementById('students-list')!.innerHTML =
      '<p class="muted" style="text-align:center;padding:2rem;">No tienes grupos aún. <a href="/assign">Crea tu primer grupo</a></p>';
  } else {
    // Revisar si viene ?grupo= en la URL
    const params     = new URLSearchParams(window.location.search);
    const grupoParam = params.get('grupo');
    const grupoInicial = grupoParam
      ? grupos.find((g: any) => String(g.grupo_id) === grupoParam) ?? grupos[0]
      : grupos[0];

    select.innerHTML = grupos.map((g: any) =>
      `<option value="${g.grupo_id}" ${g.grupo_id === grupoInicial.grupo_id ? 'selected' : ''}>${g.nombre}</option>`
    ).join('');

    cargarGrupo(grupoInicial.grupo_id);

    select.addEventListener('change', (e) => {
      const id = Number((e.target as HTMLSelectElement).value);
      window.history.pushState({}, '', `/students?grupo=${id}`);
      cargarGrupo(id);
    });
  }
</script>

<style>
  .filter-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding: 1rem 1.5rem;
  }

  .filter-bar label {
    font-weight: 600;
    color: var(--color-text-body);
    white-space: nowrap;
  }

  .filter-bar select { min-width: 260px; }

  .students-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .student-card { padding: 1.5rem; }

  .student-header {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .student-avatar {
    width: 48px;
    height: 48px;
    background-color: #515A82;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .student-info { flex: 1; }
  .student-info h2 { font-size: 1.1rem; margin-bottom: 0.2rem; }

  .student-stats {
    display: flex;
    gap: 1.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .stat-label {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-value {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-body);
  }

  .intentos h3 {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    color: white;
  }

</style>