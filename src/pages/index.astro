---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Memoreto — Iniciar sesión</title>
  </head>
  <body>
    <div class="login-wrapper">
      <div class="login-card">
        <div class="login-logo">🚀</div>
        <h1>Memoreto</h1>
        <p class="login-subtitle">Panel Docente</p>

        <form class="login-form" action="/dashboard" method="get">
          <div class="form-group">
            <label for="email">Correo electrónico</label>
            <input type="email" id="email" name="email" placeholder="profesor@ejemplo.com" required />
          </div>
          <div class="form-group">
            <label for="password">Contraseña</label>
            <input type="password" id="password" name="password" placeholder="••••••••" required />
          </div>
          <button type="submit" class="btn btn-primary login-btn">Entrar</button>
        </form>
      </div>
    </div>
  </body>
</html>

<style>
  body {
    background-color: #1D243D;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
  }

  .login-wrapper {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 2rem;
  }

  .login-card {
    background-color: #FFFFFF;
    border-radius: 16px;
    padding: 2.5rem;
    width: 100%;
    max-width: 400px;
    text-align: center;
  }

  .login-logo {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-size: 1.8rem;
    color: #1D243D;
    margin-bottom: 0.3rem;
  }

  .login-subtitle {
    color: #9AA0C8;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .login-form {
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: 0.9rem;
    font-weight: 600;
    color: #353D60;
  }

  input {
    background-color: #EEF0F8;
    border: 1px solid #E2E6F0;
    border-radius: 8px;
    color: #1D243D;
    padding: 0.6rem 1rem;
    font-size: 0.95rem;
    width: 100%;
  }

  input:focus {
    outline: 2px solid #515A82;
  }

  .login-btn {
    width: 100%;
    padding: 0.8rem;
    font-size: 1rem;
    margin-top: 0.5rem;
    background-color: #515A82;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .login-btn:hover {
    opacity: 0.85;
  }
</style>