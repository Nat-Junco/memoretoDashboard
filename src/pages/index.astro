---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Memoreto — Iniciar sesión</title>
  </head>
  <body>
    <div class="login-wrapper">
      <div class="login-card">
        <div class="login-logo">🚀</div>
        <h1>Memoreto</h1>
        <p class="login-subtitle">Panel Docente</p>

        <form id="form-login" class="login-form">
          <div class="form-group">
            <label for="email">Correo electrónico</label>
            <input type="email" id="email" placeholder="profesor@ejemplo.com" required />
          </div>
          <div class="form-group">
            <label for="password">Contraseña</label>
            <input type="password" id="password" placeholder="••••••••" required />
          </div>
          <div id="error-msg" class="error-msg" style="display:none"></div>
          <button type="submit" id="btn-submit" class="login-btn">Entrar</button>
        </form>

        <div class="divider">¿Eres alumno?</div>
        <a href="/registro" class="btn-registro">Regístrate aquí</a>
      </div>
    </div>
  </body>
</html>

<script>

  const API = 'http://localhost:5000';

  document.getElementById('form-login')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const correo   = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const errorMsg = document.getElementById('error-msg')!;
    const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;

     errorMsg.style.display = 'none';
    btnSubmit.disabled = true;
    btnSubmit.textContent = 'Entrando...';
 
    try {
      const res = await fetch(`${API}/auth/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ usuario: correo, pass: password }),
      });
 
      const data = await res.json();
 
      if (res.ok && data.valido) {
        localStorage.setItem('token',      data.token);
        localStorage.setItem('usuario_id', String(data.usuario_id));
        localStorage.setItem('nombre',     data.nombre);
        localStorage.setItem('rol',        data.rol);
        window.location.href = '/dashboard';
      } else {
        // El backend manda 403 si no es docente/admin, 401 si credenciales incorrectas
        errorMsg.textContent = data.mensaje ?? 'Correo o contraseña incorrectos';
        errorMsg.style.display = 'block';
        btnSubmit.disabled = false;
        btnSubmit.textContent = 'Entrar';
      }
    } catch (err) {
      errorMsg.textContent = 'No se pudo conectar con el servidor. Intenta de nuevo.';
      errorMsg.style.display = 'block';
      btnSubmit.disabled = false;
      btnSubmit.textContent = 'Entrar';
    }
  });
</script>

<style>
  :root { color-scheme: light; }

  body {
    background-color: #1D243D;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    font-family: 'Segoe UI', system-ui, sans-serif;
  }

  .login-wrapper {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 2rem;
  }

  .login-card {
    background-color: #FFFFFF;
    border-radius: 16px;
    padding: 2.5rem;
    width: 100%;
    max-width: 400px;
    text-align: center;
  }

  .login-logo { font-size: 3rem; margin-bottom: 0.5rem; }

  h1 { font-size: 1.8rem; color: #1D243D; margin-bottom: 0.3rem; }

  .login-subtitle {
    color: #9AA0C8;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .login-form {
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-size: 0.9rem;
    font-weight: 600;
    color: #353D60;
  }

  input {
    background-color: #EEF0F8;
    border: 1px solid #E2E6F0;
    border-radius: 8px;
    color: #1D243D;
    padding: 0.6rem 1rem;
    font-size: 0.95rem;
    width: 100%;
    box-sizing: border-box;
  }

  input:focus { outline: 2px solid #515A82; }

  .error-msg {
    color: #8C3030;
    background-color: #fee2e2;
    border-radius: 8px;
    padding: 0.6rem 1rem;
    font-size: 0.88rem;
  }

  .login-btn {
    width: 100%;
    padding: 0.8rem;
    font-size: 1rem;
    margin-top: 0.5rem;
    background-color: #515A82;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .login-btn:hover { opacity: 0.85; }

  .divider {
    margin: 1.5rem 0 1rem;
    color: #9AA0C8;
    font-size: 0.88rem;
    position: relative;
  }

  .divider::before, .divider::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 30%;
    height: 1px;
    background-color: #E2E6F0;
  }

  .divider::before { left: 0; }
  .divider::after { right: 0; }

  .btn-registro {
    display: block;
    width: 100%;
    padding: 0.75rem;
    background-color: #EEF0F8;
    color: #515A82;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    box-sizing: border-box;
    transition: background-color 0.2s;
  }

  .btn-registro:hover { background-color: #E2E6F0; }
</style>